# ===============================
# StratoAgentic .gitignore
# ===============================

# -------------------------------
# Raster tile data
# -------------------------------
data/tiles/
data/raster/
data/build/
*.tif
*.tiff
*.img
*.vrt

# -------------------------------
# Node / frontend
# -------------------------------
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.cache/
frontend/.parcel-cache/
frontend/npm-debug.log*

# -------------------------------
# Webpack
# -------------------------------
*.map

# -------------------------------
# Go
# -------------------------------
backend/bin/
backend/tmp/
*.exe
*.test
*.out

# -------------------------------
# Databases
# -------------------------------
*.db
*.sqlite
*.sqlite3

# -------------------------------
# Environment variables
# -------------------------------
.env
.env.local
.env.*

# -------------------------------
# Logs
# -------------------------------
*.log
logs/

# -------------------------------
# Docker
# -------------------------------
docker/.env

# -------------------------------
# OS files
# -------------------------------
.DS_Store
Thumbs.db

# -------------------------------
# C++ build artifacts
# -------------------------------
cpp/raster-tiler/build/
cpp/raster-tiler/*.o
cpp/raster-tiler/*.a
cpp/raster-tiler/*.so
cpp/raster-tiler/*.dll

# -------------------------------
# IDEs
# -------------------------------
.vscode/
.idea/
*.swp
*.swo